# {{{ Font Configuration
# To list fonts: kitty +list-fonts --psnames | grep JetBrains
font_family      JetBrainsMono Nerd Font
bold_font        JetBrainsMono Nerd Font Bold
italic_font      JetBrainsMono Nerd Font Italic
bold_italic_font JetBrainsMono Nerd Font Bold Italic
font_size        12.0
# Disable ligatures for better code readability (optional)
disable_ligatures never
# }}}

# {{{ Cursor Configuration
cursor_shape beam
cursor_beam_thickness 2.0
cursor_blink_interval 0.5
cursor_stop_blinking_after 15.0
# }}}

# {{{ Scrollback and Performance
scrollback_lines 10000
scrollback_pager less --chop-long-lines --RAW-CONTROL-CHARS +INPUT_LINE_NUMBER
wheel_scroll_multiplier 5.0
touch_scroll_multiplier 3.0
# }}}

# {{{ Window and Visual Settings
background_opacity 1
window_padding_width 12
window_margin_width 0
single_window_margin_width -1
window_border_width 1pt
# Modern window styling
hide_window_decorations titlebar-only
confirm_os_window_close 0
# }}}

# {{{ Mouse and Selection
mouse_hide_wait 0.3
copy_on_select clipboard
strip_trailing_spaces smart
select_by_word_characters :@-./_~?&=%+#
click_interval 0.5
focus_follows_mouse no
# }}}

# {{{ URL Handling
url_style curly
url_prefixes http https file ftp gemini irc gopher mailto news git
detect_urls yes
# }}}

# {{{ Tab Bar Configuration
tab_bar_edge bottom
tab_bar_style powerline
tab_powerline_style angled
tab_bar_min_tabs 2
tab_separator " в”Ӣ "
active_tab_font_style bold-italic
inactive_tab_font_style normal
tab_title_template "{index}: {title[title.rfind('/')+1:]}"
# }}}

# {{{ Performance Settings
repaint_delay 10
input_delay 3
sync_to_monitor yes
# }}}

# {{{ Key Bindings
kitty_mod ctrl+shift

# Clipboard
map kitty_mod+c copy_to_clipboard
map kitty_mod+v paste_from_clipboard
map cmd+c copy_to_clipboard
map cmd+v paste_from_clipboard

# Scrolling
map kitty_mod+k scroll_page_up
map kitty_mod+j scroll_page_down
map kitty_mod+home scroll_home
map kitty_mod+end scroll_end
map kitty_mod+h show_scrollback

# Font size
map kitty_mod+plus change_font_size all +2.0
map kitty_mod+minus change_font_size all -2.0
map kitty_mod+backspace change_font_size all 0
map cmd+plus change_font_size all +2.0
map cmd+minus change_font_size all -2.0

# Windows
map kitty_mod+enter new_os_window_with_cwd
map kitty_mod+n new_os_window
map cmd+n new_os_window

# Tabs
map kitty_mod+t new_tab_with_cwd
map kitty_mod+w close_tab
map kitty_mod+] next_tab
map kitty_mod+[ previous_tab
map kitty_mod+1 goto_tab 1
map kitty_mod+2 goto_tab 2
map kitty_mod+3 goto_tab 3
map kitty_mod+4 goto_tab 4
map kitty_mod+5 goto_tab 5

# Miscellaneous
map kitty_mod+r clear_terminal reset active
map kitty_mod+l clear_terminal clear active
map kitty_mod+f5 load_config_file
map kitty_mod+f6 debug_config
# }}}

